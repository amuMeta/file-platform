# .env.docker.example - Docker 部署环境变量模板
# 复制为 .env 后用 scripts/gen-secret.sh 追加 SESSION_SECRET

NODE_ENV=production
PORT=3000

# 数据(容器内路径,./data 是 bind mount 源)
DB_PATH=/app/data/app.db
UPLOAD_DIR=/app/data/uploads

# 上传限制(nginx client_max_body_size 必须 >= MAX_UPLOAD_MB + 20m)
MAX_UPLOAD_MB=500
ALLOWED_EXT=rar,zip,7z,exe,bin,img,apk

# 会话
# SESSION_SECRET=<用 scripts/gen-secret.sh 生成,64 字符 hex>
COOKIE_SECURE=true          # 公网 cpolar 提供 HTTPS,必须 true
SESSION_SECRET=__REPLACE_ME__

# 下载下发(必须 true,让 nginx X-Accel-Redirect 零拷贝下发大文件)
USE_XACCEL=true
XACCEL_PREFIX=/protected

# 初始管理员(seed 阶段使用,首登后建议改)
SEED_ADMIN_USER=admin
SEED_ADMIN_PASS=__CHANGE_ME__
