NODE_ENV=development
PORT=3000

# 数据
DB_PATH=./data/app.db
UPLOAD_DIR=./data/uploads

# 上传限制
MAX_UPLOAD_MB=500
ALLOWED_EXT=rar,zip,7z,exe,bin,img,apk

# 会话
SESSION_SECRET=change-me-to-a-long-random-string
COOKIE_SECURE=false

# 下载下发模式
USE_XACCEL=false
XACCEL_PREFIX=/protected

# 初始管理员(seed 用)
SEED_ADMIN_USER=admin
SEED_ADMIN_PASS=change-me
